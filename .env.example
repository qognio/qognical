# ============================================================================
# qognical — example configuration. Copy to .env and fill in values.
# ============================================================================
# Pflicht (sonst startet die Anwendung nicht):

QOGNICAL_BASE_URL=https://book.example.com
# 32 bytes base64. Generate with: docker run --rm ghcr.io/qognio/qognical:latest genkey
QOGNICAL_ENCRYPTION_KEY=

QOGNICAL_SMTP_HOST=smtp.example.com
QOGNICAL_SMTP_PORT=587
QOGNICAL_SMTP_USER=
QOGNICAL_SMTP_PASSWORD=
QOGNICAL_SMTP_FROM=no-reply@example.com

# ----------------------------------------------------------------------------
# Häufige Optionen:

QOGNICAL_DATA_DIR=/pb_data
QOGNICAL_LISTEN_ADDR=0.0.0.0:8090
QOGNICAL_LOG_LEVEL=info             # debug|info|warn|error
QOGNICAL_LOG_FORMAT=json            # json|text

# Comma-separated allowlist; empty = no cross-origin.
QOGNICAL_CORS_ALLOWED_ORIGINS=

QOGNICAL_RATE_LIMIT_PUBLIC=60/min
QOGNICAL_RATE_LIMIT_BOOK=5/min

QOGNICAL_CAPTCHA_PROVIDER=          # hcaptcha|turnstile|none
QOGNICAL_CAPTCHA_SITE_KEY=
QOGNICAL_CAPTCHA_SECRET=

# DSGVO-Aufbewahrung (leer = unbegrenzt für bookings):
QOGNICAL_DATA_RETENTION_BOOKINGS_DAYS=
QOGNICAL_DATA_RETENTION_AUDIT_DAYS=90
QOGNICAL_DATA_RETENTION_NOTIFICATIONS_DAYS=365

# ----------------------------------------------------------------------------
# Calendar / Meeting / Payment Provider (optional, jeweils pro Bedarf):

# Microsoft Graph (calendar + Teams Weg 1)
QOGNICAL_MSGRAPH_TENANT_ID=
QOGNICAL_MSGRAPH_CLIENT_ID=
QOGNICAL_MSGRAPH_CLIENT_SECRET=

# Google Calendar (siehe ADR-0001)
QOGNICAL_GOOGLE_CLIENT_ID=
QOGNICAL_GOOGLE_CLIENT_SECRET=
QOGNICAL_GOOGLE_REDIRECT_URI=

# Stripe
QOGNICAL_STRIPE_SECRET_KEY=
QOGNICAL_STRIPE_WEBHOOK_SECRET=
QOGNICAL_STRIPE_API_VERSION=2026-01-28

# PayPal
QOGNICAL_PAYPAL_CLIENT_ID=
QOGNICAL_PAYPAL_CLIENT_SECRET=
QOGNICAL_PAYPAL_MODE=sandbox        # sandbox|live
QOGNICAL_PAYPAL_WEBHOOK_ID=

# Jitsi (JWT-Modus)
QOGNICAL_JITSI_BASE_URL=
QOGNICAL_JITSI_JWT_SECRET=
QOGNICAL_JITSI_JWT_APP_ID=

# ----------------------------------------------------------------------------
# Secrets via Docker secrets / k8s: jede *_FILE-Variante liest den Pfad.
# Beispiel:
#   QOGNICAL_ENCRYPTION_KEY_FILE=/run/secrets/qognical_encryption_key
#   QOGNICAL_SMTP_PASSWORD_FILE=/run/secrets/qognical_smtp_pw
